# ── Streamlit ──────────────────────────────────────────────
# URL của FastAPI khi chạy local (docker compose tự override)
API_URL=http://localhost:8000

# ── MLflow ─────────────────────────────────────────────────
# Để trống nếu dùng local file tracking (mlruns/)
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

# ── AWS / DVC remote (S3) ───────────────────────────────────
# Cần nếu dùng dvc pull từ S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1

# ── DockerHub (chỉ dùng trong GitHub Actions) ───────────────
# Đặt trong GitHub → Settings → Secrets & Variables
# DOCKERHUB_USERNAME  (variable)
# DOCKERHUB_TOKEN     (secret)
